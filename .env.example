# YandexAppmetrica Configuration
# Copy this file to .env and fill in your actual values

# Required: Project ID to replicate
TAP_YANDEX_APPMETRICA_APPLICATION_ID=""

# Required: Authentication token for the API service
TAP_YANDEX_APPMETRICA_TOKEN=""

# Required: The earliest record date to sync (ISO format)
TAP_YANDEX_APPMETRICA_START_DATE="2026-01-01 00:00:00"

# Optional: Number of old days to reload every run
TAP_YANDEX_APPMETRICA_RETRO_INTERVAL_DAYS=0
